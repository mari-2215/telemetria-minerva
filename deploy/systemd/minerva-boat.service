[Unit]
Description=Telemetria Minerva - servico embarcado
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=minerva
Group=minerva
EnvironmentFile=/etc/minerva-telemetry/boat.env
ExecStart=/opt/minerva-telemetry/.venv/bin/minerva-boat
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/minerva-telemetry

[Install]
WantedBy=multi-user.target
